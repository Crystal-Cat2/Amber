{
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python D:/Work/Amber/.claude/hooks/check_sql_confirmed.py",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Stop",
        "hooks": [
          {
            "type": "command",
            "command": "cd D:/Work/Amber && git add -A && git diff --cached --quiet || git commit -m \"snapshot: auto-save\""
          }
        ]
      }
    ]
  }
}
