{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python D:/Work/Amber/.claude/hooks/block_unconfirmed_sql.py",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "mcp__Bigquery",
        "hooks": [
          {
            "type": "command",
            "command": "python D:/Work/Amber/.claude/hooks/block_unconfirmed_sql.py",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": []
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash D:/Work/Amber/.claude/hooks/auto_open_html.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash D:/Work/Amber/.claude/hooks/commit_sql_after_write.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash D:/Work/Amber/.claude/hooks/auto_extract_rules.sh",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash D:/Work/Amber/.claude/hooks/auto_record_errors.sh",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Stop",
        "hooks": [
          {
            "type": "command",
            "command": "cd D:/Work/Amber && git add -A && git diff --cached --quiet || git commit -m \"snapshot: auto-save\""
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true
  }
}
