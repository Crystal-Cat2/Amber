# 依赖 & 编译产物
node_modules/
__pycache__/
*.pyc

# 二进制 / 安装包
*.exe

# 临时产出目录
output/playwright_smoke/
git_installer/

# Claude Code 本地配置（含权限等敏感信息）
.claude/settings.local.json

